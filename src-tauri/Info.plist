<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>NSMicrophoneUsageDescription</key>
  <string>Course+ records meetings so it can transcribe and summarize them.</string>
  <!-- Disable App Nap so macOS never throttles the process while a meeting is
       recording in the background (window unfocused or hidden to the tray). -->
  <key>NSAppSleepDisabled</key>
  <true/>
</dict>
</plist>
