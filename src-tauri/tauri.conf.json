{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Course+",
  "version": "0.1.0",
  "identifier": "com.natestephenson.courseplus",
  "build": {
    "frontendDist": "shell",
    "devUrl": "https://nates123-cmd.github.io/Course-plus-app/"
  },
  "app": {
    "withGlobalTauri": true,
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Course+",
        "url": "https://nates123-cmd.github.io/Course-plus-app/",
        "width": 1280,
        "height": 832,
        "minWidth": 720,
        "minHeight": 480,
        "resizable": true,
        "center": true,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "entitlements": "Entitlements.plist"
    }
  }
}
